PORT=4000
ALLOWED_ORIGIN=http://localhost:3000
SESSION_TTL_HOURS=12
SESSION_SECRET=troque-por-uma-string-aleatoria-longa
# Usados so na primeira vez que o servidor sobe sem nenhum usuario no
# Firestore, para criar o primeiro usuario administrativo (senha em hash).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha
GCLOUD_PROJECT=bd-indicada
# Conteudo do JSON da service account do Firebase (Project settings > Service
# accounts > Generate new private key). Local: pode deixar em branco se
# `gcloud auth application-default login` ja estiver configurado.
FIREBASE_SERVICE_ACCOUNT_JSON=
